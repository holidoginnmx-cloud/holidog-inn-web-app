# ---------------------------------------------------------------
# Copia este archivo a `.env.local` y completa los valores.
# Nunca cometas `.env.local`.
# ---------------------------------------------------------------

# ---- Clerk ----------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ---- Supabase -------------------------------------------------
# URL del proyecto y anon key (seguras para el cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: SOLO en el servidor. Nunca exponerla al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref del proyecto Supabase (p. ej. abcdefghijklmnop).
# Solo lo usa el script `npm run db:types` para regenerar lib/supabase/types.ts.
SUPABASE_PROJECT_ID=
